<h1>
    <%= title %>
</h1>

<!-- Flash Message -->
<% if (typeof message !== 'undefined' && message) { %>
    <p class="notice" style="color: green;">
        <%= message %>
    </p>
<% } %>

<!-- Error Messages -->
<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <ul class="errors" style="color: red;">
        <% errors.forEach(error => { %>
            <li>
                <%= error.msg %>
            </li>
        <% }) %>
    </ul>
<% } %>

<form action="/inv/update" class="addinv" method="post" id="updateForm" onsubmit="return validateInventoryForm();" novalidate>

    <!-- Classification Dropdown -->
    <label for="classificationSelect">Classification</label>
    <%- classificationSelect %>
    <span id="classificationError" style="color: red; display: none;"></span>

    <!-- Make -->
    <label for="inv_make">Make</label>
    <input type="text" name="inv_make" id="inv_make" required
        value="<%= typeof inv_make !== 'undefined' ? inv_make : '' %>">
    <span id="makeError" style="color: red; display: none;"></span>

    <!-- Model -->
    <label for="inv_model">Model</label>
    <input type="text" name="inv_model" id="inv_model" required
        value="<%= typeof inv_model !== 'undefined' ? inv_model : '' %>">
    <span id="modelError" style="color: red; display: none;"></span>

    <!-- Year -->
    <label for="inv_year">Year</label>
    <input type="number" name="inv_year" id="inv_year" required min="1900" max="2099"
        value="<%= typeof inv_year !== 'undefined' ? inv_year : '' %>">
    <span id="yearError" style="color: red; display: none;"></span>

    <!-- Description -->
    <label for="inv_description">Description</label>
    <textarea name="inv_description" id="inv_description"
        required><%= typeof inv_description !== 'undefined' ? inv_description : '' %></textarea>
    <span id="descriptionError" style="color: red; display: none;"></span>

    <!-- Image Path -->
    <label for="inv_image">Image Path</label>
    <input type="text" name="inv_image" id="inv_image" required
        value="<%= typeof inv_image !== 'undefined' ? inv_image : '/images/vehicles/no-image.png' %>">
    <span id="imageError" style="color: red; display: none;"></span>

    <!-- Thumbnail Path -->
    <label for="inv_thumbnail">Thumbnail Path</label>
    <input type="text" name="inv_thumbnail" id="inv_thumbnail" required
        value="<%= typeof inv_thumbnail !== 'undefined' ? inv_thumbnail : '/images/vehicles/no-image-tn.png' %>">
    <span id="thumbnailError" style="color: red; display: none;"></span>

    <!-- Price -->
    <label for="inv_price">Price</label>
    <input type="number" name="inv_price" id="inv_price" required step="0.01"
        value="<%= typeof inv_price !== 'undefined' ? inv_price : '' %>">
    <span id="priceError" style="color: red; display: none;"></span>

    <!-- Miles -->
    <label for="inv_miles">Miles</label>
    <input type="number" name="inv_miles" id="inv_miles" required
        value="<%= typeof inv_miles !== 'undefined' ? inv_miles : '' %>">
    <span id="milesError" style="color: red; display: none;"></span>

    <!-- Color -->
    <label for="inv_color">Color</label>
    <input type="text" name="inv_color" id="inv_color" required
        value="<%= typeof inv_color !== 'undefined' ? inv_color : '' %>">
    <span id="colorError" style="color: red; display: none;"></span>

    <input type="hidden" name="inv_id" value="<%= inv_id %>">

    <button type="submit" disabled>Update Vehicle</button>

</form>

<script src="/js/inv-update.js"></script>
