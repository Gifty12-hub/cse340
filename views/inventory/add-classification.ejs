<h1>Add New Classification</h1>

<!-- Flash message display -->
<% if (typeof message !== 'undefined' && message) { %>
    <p class="notice" style="color: green;">
        <%= message %>
    </p>
<% } %>

<!-- Error messages from server-side validation  -->
<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <ul class="errors" style="color: red;">
        <% errors.forEach(function(err) { %>
            <li>
                <%= err.msg %>
            </li>
        <% }) %>
    </ul>
<% } %>

<form action="/inv/add-classification" method="post" onsubmit="return validateClassificationForm();" id="classificationForm">
    <label for="classification_name">Classification Name:</label>
    <input type="text" id="classification_name" name="classification_name" required>
    <span id="classificationError" style="color: red; display: none;"></span>
    <p class="hint">Letters, numbers, and spaces only. Minimum 2 characters.</p>

    <button type="submit">Add Classification</button>
</form>

<script>
function validateClassificationForm() {
    const classificationName = document.getElementById('classification_name').value.trim();
    const errorSpan = document.getElementById('classificationError');
    
    // Clear previous errors
    errorSpan.style.display = 'none';
    errorSpan.textContent = '';
    
    // Check if empty
    if (!classificationName) {
        errorSpan.textContent = 'Classification name is required.';
        errorSpan.style.display = 'block';
        return false;
    }
    
    // Check minimum length
    if (classificationName.length < 2) {
        errorSpan.textContent = 'Classification name must be at least 2 characters.';
        errorSpan.style.display = 'block';
        return false;
    }
    
    // Check for valid characters (letters, numbers, spaces only)
    if (!/^[a-zA-Z0-9\s]+$/.test(classificationName)) {
        errorSpan.textContent = 'Classification name can only contain letters, numbers, and spaces.';
        errorSpan.style.display = 'block';
        return false;
    }
    
    return true;
}
</script>