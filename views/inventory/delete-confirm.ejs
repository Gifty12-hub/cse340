<h1>Delete - <%- title %></h1>
<p>Confirm Deletion - The delete is permanent.</p>

<form action="/inv/delete" method="post">
    <label for="invYear">Year:</label>
    <input type="text" name="inv_year" value="<%= inv_year %>" readonly>

    <label for="invMake">Make:</label>
    <input type="text" name="inv_make" value="<%= inv_make %>" readonly>

    <label for="invModel">Model:</label>
    <input type="text" name="inv_model" value="<%= inv_model %>" readonly>

    <label for="invPrice">Price:</label>
    <input type="number" name="inv_price" value="<%= inv_price %>" readonly>

    <input type="hidden" name="inv_id" value="<%= inv_id %>">
    <input type="submit" value="Delete">
</form>