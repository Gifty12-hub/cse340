<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
    <% } %>

        <%- messages() %>

            <% if (user && user.account_firstname) { %>

                <% if (user.account_type==='Employee' || user.account_type==='Admin' ) { %>
                    <h2>Welcome <%= user.account_firstname %>
                    </h2>
                    <% } else { %>
                        <h2>Welcome <%= user.account_firstname %>
                        </h2>
                        <% } %>

                            <!-- Update link — visible to ALL account types -->
                            <p>
                                <a href="/account/update/<%= user.account_id %>">Update Account Information</a>
                            </p>

                            <!-- Inventory Management — Employee/Admin ONLY, h3 must NOT appear for Client -->
                            <% if (user.account_type==='Employee' || user.account_type==='Admin' ) { %>
                                <h3>Inventory Management</h3>
                                <p>
                                    <a href="/inventory">Access Inventory Management</a>
                                </p>
                                <% } %>

                                    <% } else { %>
                                        <p>Error: User information not available. Please try logging in again.</p>
                                        <% } %>