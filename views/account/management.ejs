<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
    <% } else { res.redirect('/') } %>

<% if (typeof errors !== 'undefined' && errors && errors.errors && errors.errors.length > 0) { %>
    <ul class="errors" style="color: red;">
        <% errors.errors.forEach(function(err) { %>
            <li><%= err.msg %></li>
        <% }) %>
    </ul>
<% } %>

        <%- messages() %>

        <p>You're logged in</p>