<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
    <% } else { res.redirect('/') } %>

<% if (typeof errors !== 'undefined' && errors && errors.errors && errors.errors.length > 0) { %>
    <ul class="errors" style="color: red;">
        <% errors.errors.forEach(function(err) { %>
            <li><%= err.msg %></li>
        <% }) %>
    </ul>
<% } %>

        <%- messages() %>

            <form action="/account/login" method="post" class="login-form" id="loginForm">

                <label for="account_email">Email Address</label>
                <input type="email" id="account_email" name="account_email" value="<%= locals.account_email %>" required>

                <label for="account_password">Password</label>
                <span>Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1
                    special character</span>
                <input type="password" name="account_password" id="accountPassword" required
                    pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$">

                <button type="submit">Login</button>

            </form>
            <p class="register-link">
                Don't have an account?
                <a href="/account/register">Register</a>
            </p>

<script>
  // Show pop-up message after flash message appears
  window.addEventListener('DOMContentLoaded', (event) => {
    const messageNode = document.querySelector('.alert') || document.querySelector('.notice') || document.querySelector('.flash');
    if (messageNode) {
      const text = messageNode.innerText.trim();
      if (text) {
        alert(text);
      }
    }
  });
</script>